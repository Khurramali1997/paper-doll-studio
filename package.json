{
  "name": "paperdoll-studio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Paper Doll Studio — local-first character customization tool",
  "scripts": {
    "dev": "venv/bin/python server.py",
    "dev:reload": "venv/bin/uvicorn server:app --host 0.0.0.0 --port 8000 --reload",
    "start": "venv/bin/python server.py",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npx eslint js/ tests/ --ext .js"
  },
  "devDependencies": {
    "canvas": "^3.2.3",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "vitest": "^3.1.1"
  }
}
